generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum SectionType {
  ARTICLE
  TABLE
  APPENDIX
  NOTE
  OTHER
}

enum ChunkType {
  PARAGRAPH
  RETRIEVAL
  RAG
}

enum DocumentStatus {
  ACTIVE
  ARCHIVED
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  password    String
  role        UserRole @default(VIEWER)

  created_at  DateTime @default(now())

  @@map("users")
}

//////////////////////////////////////////////////////
// DOCUMENT
//////////////////////////////////////////////////////

model Document {
  id            String   @id @default(uuid())

  title         String
  doc_code      String   @unique

  issue_date    DateTime?
  issue_date_jalali String?

  status        DocumentStatus @default(ACTIVE)

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  chunks          Chunk[]
  versions      DocumentVersion[]

  @@map("documents")
}

//////////////////////////////////////////////////////
// DOCUMENT VERSION
//////////////////////////////////////////////////////

model DocumentVersion {
  id            String   @id @default(uuid())

  documentId    String
  versionNumber Int

  file_url      String
  file_size     Int?

  created_at    DateTime @default(now())

  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  sections      DocumentSection[]
  chunks        Chunk[]

  @@unique([documentId, versionNumber])
  @@index([documentId])
  @@map("document_versions")
}
 
//////////////////////////////////////////////////////
// CHUNKS
//////////////////////////////////////////////////////

model Chunk {
  id              String   @id @default(uuid())

  versionId       String
  documentId      String
  
  pageNumber Int?
  chunkIndex      Int
  type            ChunkType

  text            String
  normalizedText  String

  paragraphStart  Int?
  paragraphEnd    Int?

  charLength      Int

  metadata        Json?

  createdAt       DateTime @default(now())

  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version         DocumentVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  embedding       Embedding?

  @@index([documentId])
  @@index([versionId])
 
  @@index([type])
  @@index([chunkIndex])
  @@map("chunks")
}

//////////////////////////////////////////////////////
// EMBEDDINGS
//////////////////////////////////////////////////////

model Embedding {
  id        String  @id @default(uuid())

  chunkId   String  @unique

  vector    Json
  model     String

  createdAt DateTime @default(now())

  chunk     Chunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@map("embeddings")
}
